<section
  class="py-12 border-b"
  style="
    background-color: {{ section.settings.bg_color }};
    border-color: {{ section.settings.border_color }};
  "
>
  <div
    class="mx-auto px-4 sm:px-6 lg:px-8 flex justify-center"
  >
    <div class="!grid !grid-cols-2 md:flex md:flex-wrap items-center justify-between w-full gap-8 component-width">
      {% for block in section.blocks %}
        <div class="flex flex-col items-center text-center flex-1 min-w-35" {{ block.shopify_attributes }}>
          <div
            class="mb-3"
            style="
              width: {{ section.settings.icon_size }}px;
              height: {{ section.settings.icon_size }}px;
              color: {{ section.settings.icon_color }};
            "
          >
            {% case block.settings.icon %}
              {% when 'package' %}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path>
                  <path d="M12 22V12"></path>
                  <polyline points="3.29 7 12 12 20.71 7"></polyline>
                  <path d="m7.5 4.27 9 5.15"></path>
                </svg>
              {% when 'truck' %}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
                  <path d="M15 18H9"></path>
                  <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path>
                  <circle cx="17" cy="18" r="2"></circle>
                  <circle cx="7" cy="18" r="2"></circle>
                </svg>
              {% when 'shield-check' %}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                  <path d="m9 12 2 2 4-4"></path>
                </svg>
              {% when 'file-text' %}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
                  <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
                  <path d="M10 9H8"></path>
                  <path d="M16 13H8"></path>
                  <path d="M16 17H8"></path>
                </svg>
            {% endcase %}
          </div>

          <span
            class="font-bold"
            style="
              font-size: {{ section.settings.value_size }}px;
              color: {{ section.settings.value_color }};
            "
          >
            {{ block.settings.value }}
          </span>

          <span
            style="
              font-size: {{ section.settings.label_size }}px;
              color: {{ section.settings.label_color }};
              text-transform: uppercase;
              letter-spacing: 0.15em;
              opacity: {{ section.settings.label_opacity | divided_by: 100.0 }};
            "
          >
            {{ block.settings.label }}
          </span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .component-width{
    max-width:{{ section.settings.max_width }}px
  }
</style>

{% schema %}
{
  "name": "App Icon",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "number",
      "id": "max_width",
      "label": "Maximum Width",
      "default": 1280
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#c48a3a"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Value color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 80,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Value font size",
      "min": 14,
      "max": 48,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "label_opacity",
      "label": "Label opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "package",
          "options": [
            { "value": "package", "label": "Package" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield-check", "label": "Shield Check" },
            { "value": "file-text", "label": "File Text" }
          ]
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "150+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Bobrick Products"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "App Icon",
      "blocks": [
        {
          "type": "icon_item",
          "settings": {
            "icon": "package",
            "value": "150+",
            "label": "Bobrick Products"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "truck",
            "value": "Nationwide",
            "label": "Fast Shipping"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "shield-check",
            "value": "ADA",
            "label": "Compliant Materials"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "file-text",
            "value": "RFQ",
            "label": "Quick Turnaround"
          }
        }
      ]
    }
  ]
}
{% endschema %}
