{% liquid
  assign section_id = 'app-footer-' | append: section.id
%}

<footer id="{{ section_id }}" class="app-footer">
  <style>
    #{{ section_id }} {
      --footer-bg: {{ section.settings.footer_bg }};
      --footer-text: {{ section.settings.footer_text_color }};
      --footer-muted: {{ section.settings.footer_muted_color }};
      --footer-heading: {{ section.settings.footer_heading_color }};
      --footer-link-hover: {{ section.settings.footer_link_hover_color }};
      --footer-border: {{ section.settings.footer_border_color }};
      --container-width: {{ section.settings.container_width }}px;
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
      --grid-gap: {{ section.settings.grid_gap }}px;
      --bottom-gap: {{ section.settings.bottom_gap }}px;
      background: var(--footer-bg);
      color: var(--footer-text);
    }

    #{{ section_id }} .app-footer__inner {
      max-width: var(--container-width);
      margin: 0 auto;
      padding: var(--padding-top) 16px var(--padding-bottom);
    }

    #{{ section_id }} .app-footer__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--grid-gap);
      margin-bottom: 64px;
    }

    @media (min-width: 768px) {
      #{{ section_id }} .app-footer__grid {
        grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr);
      }
    }

    #{{ section_id }} .app-footer__brand {
      max-width: 680px;
    }

    #{{ section_id }} .app-footer__brand-link {
      display: inline-flex;
      flex-direction: column;
      text-decoration: none;
      margin-bottom: 24px;
      color: inherit;
    }

    #{{ section_id }} .app-footer__brand-title {
      font-size: {{ section.settings.brand_title_size }}px;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1;
      color: {{ section.settings.brand_title_color }};
      margin: 0;
    }

    #{{ section_id }} .app-footer__brand-subtitle {
      margin-top: 6px;
      font-size: {{ section.settings.brand_subtitle_size }}px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-weight: 500;
      line-height: 1.2;
      color: {{ section.settings.brand_subtitle_color }};
    }

    #{{ section_id }} .app-footer__description {
      max-width: {{ section.settings.description_width }}px;
      margin: 0 0 28px;
      color: var(--footer-muted);
      font-size: {{ section.settings.description_size }}px;
      line-height: 1.7;
    }

    #{{ section_id }} .app-footer__contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 18px 24px;
    }

    #{{ section_id }} .app-footer__contact-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--footer-muted);
      text-decoration: none;
      transition: color 0.25s ease;
      font-size: {{ section.settings.contact_size }}px;
    }

    #{{ section_id }} .app-footer__contact-link:hover {
      color: var(--footer-link-hover);
    }

    #{{ section_id }} .app-footer__contact-link svg {
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
    }

    #{{ section_id }} .app-footer__column-title {
      margin: 0 0 24px;
      font-size: {{ section.settings.column_heading_size }}px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--footer-heading);
    }

    #{{ section_id }} .app-footer__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    #{{ section_id }} .app-footer__list-link {
      color: var(--footer-muted);
      text-decoration: none;
      transition: color 0.25s ease;
      font-size: {{ section.settings.link_size }}px;
      line-height: 1.5;
    }

    #{{ section_id }} .app-footer__list-link:hover {
      color: var(--footer-link-hover);
    }

    #{{ section_id }} .app-footer__bottom {
      padding-top: {{ section.settings.bottom_padding_top }}px;
      border-top: 1px solid var(--footer-border);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      gap: var(--bottom-gap);
      font-size: {{ section.settings.bottom_text_size }}px;
      color: {{ section.settings.bottom_text_color }};
    }

    @media (min-width: 768px) {
      #{{ section_id }} .app-footer__bottom {
        flex-direction: row;
      }
    }

    #{{ section_id }} .app-footer__bottom p {
      margin: 0;
    }

    #{{ section_id }} .app-footer__legal {
      display: flex;
      flex-wrap: wrap;
      gap: 16px 32px;
      align-items: center;
      justify-content: center;
    }

    #{{ section_id }} .app-footer__legal a {
      color: {{ section.settings.bottom_link_color }};
      text-decoration: none;
      transition: color 0.25s ease;
    }

    #{{ section_id }} .app-footer__legal a:hover {
      color: {{ section.settings.bottom_link_hover_color }};
    }

    @media (max-width: 767px) {
      #{{ section_id }} .app-footer__brand-title {
        font-size: {{ section.settings.brand_title_size_mobile }}px;
      }

      #{{ section_id }} .app-footer__brand-subtitle {
        font-size: {{ section.settings.brand_subtitle_size_mobile }}px;
      }

      #{{ section_id }} .app-footer__description {
        font-size: {{ section.settings.description_size_mobile }}px;
      }
    }
  </style>

  <div class="app-footer__inner">
    <div class="app-footer__grid">
      <div class="app-footer__brand">
        <a
          class="app-footer__brand-link"
          href="{% if section.settings.brand_link != blank %}{{ section.settings.brand_link }}{% else %}{{ routes.root_url }}{% endif %}"
        >
          {% if section.settings.brand_title != blank %}
            <span class="app-footer__brand-title">{{ section.settings.brand_title }}</span>
          {% endif %}
          {% if section.settings.brand_subtitle != blank %}
            <span class="app-footer__brand-subtitle">{{ section.settings.brand_subtitle }}</span>
          {% endif %}
        </a>

        {% if section.settings.description != blank %}
          <div class="app-footer__description rte">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.show_contact_row %}
          <div class="app-footer__contact-row">
            {% if section.settings.phone_text != blank %}
              <a
                href="{% if section.settings.phone_link != blank %}{{ section.settings.phone_link }}{% else %}tel:{{ section.settings.phone_text | replace: ' ', '' }}{% endif %}"
                class="app-footer__contact-link"
              >
                {% if section.settings.show_phone_icon %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="{{ section.settings.icon_stroke_width }}"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"></path>
                  </svg>
                {% endif %}
                <span>{{ section.settings.phone_text }}</span>
              </a>
            {% endif %}

            {% if section.settings.email_text != blank %}
              <a
                href="{% if section.settings.email_link != blank %}{{ section.settings.email_link }}{% else %}mailto:{{ section.settings.email_text }}{% endif %}"
                class="app-footer__contact-link"
              >
                {% if section.settings.show_email_icon %}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="{{ section.settings.icon_stroke_width }}"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path>
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  </svg>
                {% endif %}
                <span>{{ section.settings.email_text }}</span>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="app-footer__column">
        {% if section.settings.quick_links_heading != blank %}
          <h4 class="app-footer__column-title">{{ section.settings.quick_links_heading }}</h4>
        {% endif %}
        <ul class="app-footer__list">
          {% for block in section.blocks %}
            {% if block.type == 'quick_link' %}
              <li {{ block.shopify_attributes }}>
                <a
                  class="app-footer__list-link"
                  href="{% if block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                >
                  {{ block.settings.label }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="app-footer__column">
        {% if section.settings.categories_heading != blank %}
          <h4 class="app-footer__column-title">{{ section.settings.categories_heading }}</h4>
        {% endif %}
        <ul class="app-footer__list">
          {% for block in section.blocks %}
            {% if block.type == 'category_link' %}
              <li {{ block.shopify_attributes }}>
                <a
                  class="app-footer__list-link"
                  href="{% if block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}"
                >
                  {{ block.settings.label }}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="app-footer__bottom">
      <p>{{ section.settings.copyright_text }}</p>

      <div class="app-footer__legal">
        {% if section.settings.privacy_label != blank %}
          <a href="{% if section.settings.privacy_link != blank %}{{ section.settings.privacy_link }}{% else %}#{% endif %}">
            {{ section.settings.privacy_label }}
          </a>
        {% endif %}

        {% if section.settings.terms_label != blank %}
          <a href="{% if section.settings.terms_link != blank %}{{ section.settings.terms_link }}{% else %}#{% endif %}">
            {{ section.settings.terms_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

