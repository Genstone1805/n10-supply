    {
      "type": "checkbox",
      "id": "enable_hover_zoom",
      "label": "Enable image hover zoom",
      "default": true
    },
    {
      "type": "range",
      "id": "zoom_scale",
      "label": "Hover zoom scale",
      "min": 1,
      "max": 1.2,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sku_prefix",
      "label": "SKU prefix",
      "default": "SKU: "
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Details"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "select",
          "id": "image_ratio",
