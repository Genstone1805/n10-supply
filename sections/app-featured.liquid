  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Home Featured Product",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "image_ratio": "square"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_ratio": "square"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_ratio": "square"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_ratio": "square"
          }
        }
      ]
    }
  ]
}
{% endschema %}
