{% liquid
  assign section_id = 'quote-form-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class=""
  style="background: {{ section.settings.section_bg }}; padding-top:{{ section.settings.section_padding_top }}px; padding-bottom:{{ section.settings.section_padding_bottom }}px"
>
  <style>
    #{{ section_id }} .quote-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: {{ section.settings.grid_gap_mobile }}px;
    }

    @media (min-width: 1024px) {
      #{{ section_id }} .quote-grid {
        grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
        gap: {{ section.settings.grid_gap_desktop }}px;
      }
    }

    #{{ section_id }} .quote-main-card,
    #{{ section_id }} .quote-contact-card,
    #{{ section_id }} .quote-benefits-card {
      border-radius: {{ section.settings.card_radius }}px;
    }

    #{{ section_id }} .quote-main-card {
      background: {{ section.settings.form_card_bg }};
      border: 1px solid {{ section.settings.form_card_border }};
      box-shadow: {% if section.settings.enable_form_shadow %}0 10px 30px rgba(0,0,0,.08){% else %}none{% endif %};
      padding: {{ section.settings.form_card_padding_mobile }}px;
    }

    @media (min-width: 768px) {
      #{{ section_id }} .quote-main-card {
        padding: {{ section.settings.form_card_padding_desktop }}px;
      }
    }

    #{{ section_id }} .quote-benefits-card {
      background: {{ section.settings.benefits_card_bg }};
      color: {{ section.settings.benefits_text_color }};
      box-shadow: {% if section.settings.enable_benefits_shadow %}0 18px 40px rgba(0,0,0,.16){% else %}none{% endif %};
      padding: {{ section.settings.side_card_padding }}px;
    }

    #{{ section_id }} .quote-contact-card {
      background: {{ section.settings.contact_card_bg }};
      border: 1px solid {{ section.settings.contact_card_border }};
      color: {{ section.settings.contact_text_color }};
      padding: {{ section.settings.side_card_padding }}px;
    }

    #{{ section_id }} .quote-label {
      color: {{ section.settings.label_color }};
      font-size: {{ section.settings.label_font_size }}px;
      letter-spacing: {{ section.settings.label_letter_spacing }}em;
    }

    #{{ section_id }} .quote-input,
    #{{ section_id }} .quote-textarea,
    #{{ section_id }} .quote-file-ui {
      background: {{ section.settings.input_bg }};
      border: 1px solid {{ section.settings.input_border_color }};
      border-radius: {{ section.settings.input_radius }}px;
      color: {{ section.settings.input_text_color }};
    }

    #{{ section_id }} .quote-input,
    #{{ section_id }} .quote-textarea {
      padding: {{ section.settings.input_padding_y }}px {{ section.settings.input_padding_x }}px;
      font-size: {{ section.settings.input_font_size }}px;
    }

    #{{ section_id }} .quote-input::placeholder,
    #{{ section_id }} .quote-textarea::placeholder {
      color: {{ section.settings.placeholder_color }};
    }

    #{{ section_id }} .quote-input:focus,
    #{{ section_id }} .quote-textarea:focus {
      outline: none;
      border-color: {{ section.settings.input_focus_border_color }};
      box-shadow: 0 0 0 {{ section.settings.input_focus_ring_width }}px {{ section.settings.input_focus_ring_color }};
    }

    #{{ section_id }} .quote-file-ui {
      border-style: dashed;
      border-width: {{ section.settings.upload_border_width }}px;
      min-height: {{ section.settings.upload_box_min_height }}px;
      transition: .25s ease;
    }

    #{{ section_id }} .quote-upload-wrap:hover .quote-file-ui {
      border-color: {{ section.settings.upload_hover_border_color }};
    }

    #{{ section_id }} .quote-submit-btn {
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text_color }};
      border-radius: {{ section.settings.button_radius }}px;
      font-size: {{ section.settings.button_font_size }}px;
      padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
      justify-content: {{ section.settings.button_alignment }};
    }

    #{{ section_id }} .quote-submit-btn:hover {
      background: {{ section.settings.button_bg_hover }};
    }

    #{{ section_id }} .quote-benefit-title,
    #{{ section_id }} .quote-contact-title {
      color: inherit;
      font-size: {{ section.settings.side_title_size }}px;
    }

    #{{ section_id }} .quote-benefit-item-title {
      font-size: {{ section.settings.benefit_item_title_size }}px;
      color: {{ section.settings.benefits_heading_color }};
    }

    #{{ section_id }} .quote-benefit-item-text {
      font-size: {{ section.settings.benefit_item_text_size }}px;
      color: {{ section.settings.benefits_body_color }};
    }

    #{{ section_id }} .quote-contact-item-text {
      font-size: {{ section.settings.contact_item_text_size }}px;
      color: {{ section.settings.contact_text_color }};
    }

    #{{ section_id }} .quote-icon-box-benefits {
      background: {{ section.settings.benefit_icon_bg }};
      border-radius: {{ section.settings.icon_radius }}px;
    }

    #{{ section_id }} .quote-icon-box-contact {
      background: {{ section.settings.contact_icon_bg }};
      border-radius: {{ section.settings.icon_radius }}px;
    }

    #{{ section_id }} .quote-divider-space > * + * {
      margin-top: {{ section.settings.side_items_spacing }}px;
    }

    #{{ section_id }} .quote-form-space > * + * {
      margin-top: {{ section.settings.form_fields_spacing }}px;
    }

    #{{ section_id }} .quote-heading {
      color: {{ section.settings.form_heading_color }};
      font-size: {{ section.settings.form_heading_size }}px;
      margin-bottom: {{ section.settings.form_heading_spacing }}px;
    }

    #{{ section_id }} .quote-subheading {
      color: {{ section.settings.form_subheading_color }};
      font-size: {{ section.settings.form_subheading_size }}px;
      margin-bottom: {{ section.settings.form_subheading_spacing }}px;
    }

    #{{ section_id }} .quote-helper {
      color: {{ section.settings.upload_helper_color }};
      font-size: {{ section.settings.upload_helper_size }}px;
    }

    #{{ section_id }} .quote-upload-title {
      color: {{ section.settings.upload_title_color }};
      font-size: {{ section.settings.upload_title_size }}px;
    }

    #{{ section_id }} .quote-stack-cards > * + * {
      margin-top: {{ section.settings.sidebar_cards_spacing }}px;
    }

    #{{ section_id }} .quote-field-grid-2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: {{ section.settings.form_grid_gap_mobile }}px;
    }

    @media (min-width: 768px) {
      #{{ section_id }} .quote-field-grid-2 {
        grid-template-columns: 1fr 1fr;
        gap: {{ section.settings.form_grid_gap_desktop }}px;
      }
    }
  </style>

  <div class="max-sec-width mx-auto px-4 sm:px-6 lg:px-8">
    {% if section.settings.show_section_intro %}
      <div class="mb-10 text-center">
        {% if section.settings.section_title != blank %}
          <h2 class="quote-heading font-bold">{{ section.settings.section_title }}</h2>
        {% endif %}
        {% if section.settings.section_subtitle != blank %}
          <div class="quote-subheading">{{ section.settings.section_subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="quote-grid">
      <div>
        <div class="quote-main-card">
          {% if section.settings.form_title != blank %}
            <h3 class="quote-heading font-bold">{{ section.settings.form_title }}</h3>
          {% endif %}

          {% if section.settings.form_subtitle != blank %}
            <div class="quote-subheading">{{ section.settings.form_subtitle }}</div>
          {% endif %}

          {% form 'contact', class: 'quote-form-space' %}
            {% if form.posted_successfully? %}
              <div
                style="
                  padding: 16px 20px;
                  border-radius: {{ section.settings.input_radius }}px;
                  background: {{ section.settings.success_bg }};
                  color: {{ section.settings.success_text }};
                  border: 1px solid {{ section.settings.success_border }};
                "
              >
                {{ section.settings.success_message }}
              </div>
            {% endif %}

            {% if form.errors %}
              <div
                style="
                  padding: 16px 20px;
                  border-radius: {{ section.settings.input_radius }}px;
                  background: {{ section.settings.error_bg }};
                  color: {{ section.settings.error_text }};
                  border: 1px solid {{ section.settings.error_border }};
                "
              >
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="quote-field-grid-2">
              {% if section.settings.show_full_name %}
                <div class="space-y-2">
                  <label class="quote-label font-bold uppercase" for="QuoteForm-Name-{{ section.id }}">
                    {{ section.settings.full_name_label }}
                  </label>
                  <input
                    id="QuoteForm-Name-{{ section.id }}"
                    class="quote-input w-full"
                    type="text"
                    name="contact[{{ section.settings.full_name_field_name }}]"
                    value="{% if form[section.settings.full_name_field_name] %}{{ form[section.settings.full_name_field_name] }}{% endif %}"
                    placeholder="{{ section.settings.full_name_placeholder }}"
                    {% if section.settings.full_name_required %}
                      required
                    {% endif %}
                  >
                </div>
              {% endif %}

              {% if section.settings.show_company_name %}
                <div class="space-y-2">
                  <label class="quote-label font-bold uppercase" for="QuoteForm-Company-{{ section.id }}">
                    {{ section.settings.company_name_label }}
                  </label>
                  <input
                    id="QuoteForm-Company-{{ section.id }}"
                    class="quote-input w-full"
                    type="text"
                    name="contact[{{ section.settings.company_name_field_name }}]"
                    value="{% if form[section.settings.company_name_field_name] %}{{ form[section.settings.company_name_field_name] }}{% endif %}"
                    placeholder="{{ section.settings.company_name_placeholder }}"
                    {% if section.settings.company_name_required %}
                      required
                    {% endif %}
                  >
                </div>
              {% endif %}
            </div>

            <div class="quote-field-grid-2">
              {% if section.settings.show_email %}
                <div class="space-y-2">
                  <label class="quote-label font-bold uppercase" for="QuoteForm-Email-{{ section.id }}">
                    {{ section.settings.email_label }}
                  </label>
                  <input
                    id="QuoteForm-Email-{{ section.id }}"
                    class="quote-input w-full"
                    type="email"
                    name="contact[email]"
                    autocorrect="off"
                    autocapitalize="off"
                    value="{% if form.email %}{{ form.email }}{% endif %}"
                    placeholder="{{ section.settings.email_placeholder }}"
                    {% if section.settings.email_required %}
                      required
                    {% endif %}
                  >
                </div>
              {% endif %}

              {% if section.settings.show_phone %}
                <div class="space-y-2">
                  <label class="quote-label font-bold uppercase" for="QuoteForm-Phone-{{ section.id }}">
                    {{ section.settings.phone_label }}
                  </label>
                  <input
                    id="QuoteForm-Phone-{{ section.id }}"
                    class="quote-input w-full"
                    type="tel"
                    name="contact[{{ section.settings.phone_field_name }}]"
                    value="{% if form[section.settings.phone_field_name] %}{{ form[section.settings.phone_field_name] }}{% endif %}"
                    placeholder="{{ section.settings.phone_placeholder }}"
                    {% if section.settings.phone_required %}
                      required
                    {% endif %}
                  >
                </div>
              {% endif %}
            </div>

            {% if section.settings.show_project_name %}
              <div class="space-y-2">
                <label class="quote-label font-bold uppercase" for="QuoteForm-Project-{{ section.id }}">
                  {{ section.settings.project_label }}
                </label>
                <input
                  id="QuoteForm-Project-{{ section.id }}"
                  class="quote-input w-full"
                  type="text"
                  name="contact[{{ section.settings.project_field_name }}]"
                  value="{% if form[section.settings.project_field_name] %}{{ form[section.settings.project_field_name] }}{% endif %}"
                  placeholder="{{ section.settings.project_placeholder }}"
                  {% if section.settings.project_required %}
                    required
                  {% endif %}
                >
              </div>
            {% endif %}

            {% if section.settings.show_requirements %}
              <div class="space-y-2">
                <label class="quote-label font-bold uppercase" for="QuoteForm-Requirements-{{ section.id }}">
                  {{ section.settings.requirements_label }}
                </label>
                <textarea
                  id="QuoteForm-Requirements-{{ section.id }}"
                  class="quote-textarea w-full resize-none"
                  rows="{{ section.settings.requirements_rows }}"
                  name="contact[body]"
                  placeholder="{{ section.settings.requirements_placeholder }}"
                  {% if section.settings.requirements_required %}
                    required
                  {% endif %}
                >{% if form.body %}{{ form.body }}{% endif %}</textarea>
              </div>
            {% endif %}

            {% if section.settings.show_upload_ui %}
              <div class="space-y-2">
                <label class="quote-label font-bold uppercase">
                  {{ section.settings.upload_label }}
                </label>

                <div class="quote-upload-wrap relative group">
                  <input
                    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                    type="file"
                    {% if section.settings.allow_multiple_files %}
                      multiple
                    {% endif %}
                    accept="{{ section.settings.upload_accept }}"
                    {% if section.settings.upload_required %}
                      required
                    {% endif %}
                  >
                  <div class="quote-file-ui w-full flex flex-col items-center justify-center text-center px-6 py-8 space-y-2">
                    {% if section.settings.show_upload_icon %}
                      <div
                        style="
                          padding: 12px;
                          border-radius: 999px;
                          background: {{ section.settings.upload_icon_bg }};
                          color: {{ section.settings.upload_icon_color }};
                        "
                      >
                        {{ section.settings.upload_icon_svg }}
                      </div>
                    {% endif %}

                    {% if section.settings.upload_title != blank %}
                      <p class="quote-upload-title font-medium">{{ section.settings.upload_title }}</p>
                    {% endif %}

                    {% if section.settings.upload_helper_text != blank %}
                      <p class="quote-helper">{{ section.settings.upload_helper_text }}</p>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}

            {% if section.settings.enable_note_above_button and section.settings.note_above_button != blank %}
              <div
                style="
                  color: {{ section.settings.note_text_color }};
                  font-size: {{ section.settings.note_text_size }}px;
                "
              >
                {{ section.settings.note_above_button }}
              </div>
            {% endif %}

            <button
              type="submit"
              class="quote-submit-btn w-full font-bold flex items-center gap-3 transition-all"
            >
              <span>{{ section.settings.button_text }}</span>
              {% if section.settings.show_button_icon %}
                <span style="display:inline-flex; line-height:0;">{{ section.settings.button_icon_svg }}</span>
              {% endif %}
            </button>
          {% endform %}
        </div>
      </div>

      <div class="quote-stack-cards">
        {% if section.settings.show_benefits_card %}
          <div class="quote-benefits-card">
            {% if section.settings.benefits_title != blank %}
              <h3 class="quote-benefit-title font-bold mb-6">{{ section.settings.benefits_title }}</h3>
            {% endif %}

            <div class="quote-divider-space">
              {% for block in section.blocks %}
                {% if block.type == 'benefit' %}
                  <div class="flex items-start space-x-4" {{ block.shopify_attributes }}>
                    {% if block.settings.show_icon %}
                      <div class="quote-icon-box-benefits p-2">
                        <span style="display:inline-flex; color: {{ block.settings.icon_color }};">
                          {{ block.settings.icon_svg }}
                        </span>
                      </div>
                    {% endif %}
                    <div>
                      {% if block.settings.title != blank %}
                        <h4 class="quote-benefit-item-title font-bold">{{ block.settings.title }}</h4>
                      {% endif %}
                      {% if block.settings.text != blank %}
                        <p class="quote-benefit-item-text mt-1">{{ block.settings.text }}</p>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if section.settings.show_contact_card %}
          <div class="quote-contact-card">
            {% if section.settings.contact_title != blank %}
              <h3 class="quote-contact-title font-bold mb-6">{{ section.settings.contact_title }}</h3>
            {% endif %}

            <div class="quote-divider-space">
              {% for block in section.blocks %}
                {% if block.type == 'contact_item' %}
                  <div class="flex items-center space-x-4" {{ block.shopify_attributes }}>
                    {% if block.settings.show_icon %}
                      <div class="quote-icon-box-contact p-2">
                        <span style="display:inline-flex; color: {{ block.settings.icon_color }};">
                          {{ block.settings.icon_svg }}
                        </span>
                      </div>
                    {% endif %}
                    {% if block.settings.link != blank %}
                      <a
                        href="{{ block.settings.link }}"
                        class="quote-contact-item-text font-medium"
                        style="text-decoration:none;"
                      >
                        {{ block.settings.text }}
                      </a>
                    {% else %}
                      <span class="quote-contact-item-text font-medium">{{ block.settings.text }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <style>
    .max-sec-width{
      width:100%;
      max-width:{{section.settings.max_width }}
    }
  </style>

  {% schema %}
{
  "name": "App Quote Form",
  "tag": "section",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section intro"
    },
    {
      "type": "checkbox",
      "id": "show_section_intro",
      "label": "Show section intro",
      "default": false
    },
    {
      "type": "number",
      "id": "max_width",
      "label": "Maximum Width",
      "default": 1280
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Request a Quote"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Section subtitle",
      "default": "Tell us about your project and hardware requirements."
    },

    {
      "type": "header",
      "content": "Form header"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "Get Your Quote"
    },
    {
      "type": "textarea",
      "id": "form_subtitle",
      "label": "Form subtitle",
      "default": "Fill in the details below and our team will get back to you."
    },

    {
      "type": "header",
      "content": "Form fields visibility"
    },
    {
      "type": "checkbox",
      "id": "show_full_name",
      "label": "Show Full Name field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_company_name",
      "label": "Show Company Name field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show Email field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show Phone field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_project_name",
      "label": "Show Project field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_requirements",
      "label": "Show Requirements field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_upload_ui",
      "label": "Show Upload UI",
      "default": true
    },

    {
      "type": "header",
      "content": "Field labels and placeholders"
    },
    {
      "type": "text",
      "id": "full_name_label",
      "label": "Full Name label",
      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "full_name_placeholder",
      "label": "Full Name placeholder",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "full_name_field_name",
      "label": "Full Name field key",
      "default": "Full Name"
    },
    {
      "type": "checkbox",
      "id": "full_name_required",
      "label": "Full Name required",
      "default": true
    },

    {
      "type": "text",
      "id": "company_name_label",
      "label": "Company Name label",
      "default": "Company Name"
    },
    {
      "type": "text",
      "id": "company_name_placeholder",
      "label": "Company Name placeholder",
      "default": "Construction Co."
    },
    {
      "type": "text",
      "id": "company_name_field_name",
      "label": "Company Name field key",
      "default": "Company Name"
    },
    {
      "type": "checkbox",
      "id": "company_name_required",
      "label": "Company Name required",
      "default": true
    },

    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email Address"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "john@company.com"
    },
    {
      "type": "checkbox",
      "id": "email_required",
      "label": "Email required",
      "default": true
    },

    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone Number"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder",
      "default": "(555) 000-0000"
    },
    {
      "type": "text",
      "id": "phone_field_name",
      "label": "Phone field key",
      "default": "Phone Number"
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": true
    },

    {
      "type": "text",
      "id": "project_label",
      "label": "Project label",
      "default": "Project Name & Location"
    },
    {
      "type": "text",
      "id": "project_placeholder",
      "label": "Project placeholder",
      "default": "City Center Plaza - Austin, TX"
    },
    {
      "type": "text",
      "id": "project_field_name",
      "label": "Project field key",
      "default": "Project Name & Location"
    },
    {
      "type": "checkbox",
      "id": "project_required",
      "label": "Project required",
      "default": true
    },

    {
      "type": "text",
      "id": "requirements_label",
      "label": "Requirements label",
      "default": "Product Requirements / Hardware Schedule"
    },
    {
      "type": "textarea",
      "id": "requirements_placeholder",
      "label": "Requirements placeholder",
      "default": "Please list the model numbers and quantities needed, or paste your hardware schedule here..."
    },
    {
      "type": "range",
      "id": "requirements_rows",
      "label": "Requirements rows",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "requirements_required",
      "label": "Requirements required",
      "default": true
    },

    {
      "type": "header",
      "content": "Upload box"
    },
    {
      "type": "text",
      "id": "upload_label",
      "label": "Upload label",
      "default": "Upload Plans / Blueprints"
    },
    {
      "type": "text",
      "id": "upload_title",
      "label": "Upload title",
      "default": "Click to upload or drag and drop"
    },
    {
      "type": "text",
      "id": "upload_helper_text",
      "label": "Upload helper text",
      "default": "PDF, JPG, or PNG up to 20MB"
    },
    {
      "type": "text",
      "id": "upload_accept",
      "label": "Accepted file types",
      "default": ".pdf,.jpg,.jpeg,.png"
    },
    {
      "type": "checkbox",
      "id": "allow_multiple_files",
      "label": "Allow multiple files",
      "default": true
    },
