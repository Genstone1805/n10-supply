{% liquid
  assign section_id = 'app-cta-' | append: section.id
%}

<section id="{{ section_id }}" class="app-cta-section">
  <style>
    #{{ section_id }} {
      background: {{ section.settings.section_bg }};
    }

    #{{ section_id }} .app-cta__inner {
      max-width: {{ section.settings.content_width }}px;
      margin: 0 auto;
      padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
      text-align: {{ section.settings.text_alignment }};
    }

    #{{ section_id }} .app-cta__heading {
      margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
      color: {{ section.settings.heading_color }};
      font-size: {{ section.settings.heading_size_desktop }}px;
      line-height: 1.2;
      font-weight: 700;
    }

    #{{ section_id }} .app-cta__text {
      margin: 0 auto {{ section.settings.text_margin_bottom }}px;
      max-width: {{ section.settings.text_width }}px;
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.text_size }}px;
      line-height: 1.7;
    }

    #{{ section_id }} .app-cta__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: {{ section.settings.button_gap }}px;
      padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text_color }};
      font-size: {{ section.settings.button_text_size }}px;
      font-weight: 700;
      text-decoration: none;
      border-radius: {{ section.settings.button_radius }}px;
      border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
      box-shadow: {% if section.settings.enable_shadow %}0 12px 30px rgba(0,0,0,0.16){% else %}none{% endif %};
      transition: transform 0.25s ease, background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    #{{ section_id }} .app-cta__button:hover {
      transform: scale({{ section.settings.button_hover_scale }});
      background: {{ section.settings.button_hover_bg }};
      color: {{ section.settings.button_hover_text_color }};
      border-color: {{ section.settings.button_hover_border_color }};
    }

    #{{ section_id }} .app-cta__icon {
      width: {{ section.settings.icon_size }}px;
      height: {{ section.settings.icon_size }}px;
      flex: 0 0 auto;
    }

    @media (max-width: 767px) {
      #{{ section_id }} .app-cta__heading {
        font-size: {{ section.settings.heading_size_mobile }}px;
      }

      #{{ section_id }} .app-cta__text {
        font-size: {{ section.settings.text_size_mobile }}px;
      }

      #{{ section_id }} .app-cta__button {
        font-size: {{ section.settings.button_text_size_mobile }}px;
      }
    }
  </style>

  <div class="app-cta__inner">
    {% if section.settings.heading != blank %}
      <h2 class="app-cta__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="app-cta__text rte">{{ section.settings.description }}</div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a
        class="app-cta__button"
        href="{% if section.settings.button_link != blank %}{{ section.settings.button_link }}{% else %}#{% endif %}"
      >
        <span>{{ section.settings.button_label }}</span>

        {% if section.settings.show_icon %}
          <svg
            class="app-cta__icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="{{ section.settings.icon_stroke_width }}"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        {% endif %}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "App CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need a Custom Quote for Your Project?"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our team specializes in large-scale commercial bids. Send us your hardware schedule or product list and we'll provide competitive pricing within 24 hours.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Request a Project Quote"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "default": 1280
    },
    {
      "type": "range",
      "id": "text_width",
      "label": "Description max width",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 670
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 220,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 220,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Space below heading",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "text_margin_bottom",
      "label": "Space below description",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 40
    },

    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background color",
      "default": "#d8aa57"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#16212b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#4b5563"
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 20,
      "max": 72,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Description size desktop",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Description size mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "button_text_size_mobile",
      "label": "Button text size mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15
    },

    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#16212b"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border color",
      "default": "#16212b"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#0f1720"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Button hover border color",
      "default": "#0f1720"
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Button horizontal padding",
      "min": 12,
      "max": 60,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Button vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 100
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Space between text and icon",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "button_hover_scale",
      "label": "Button hover scale",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Enable button shadow",
      "default": true
    },

    {
      "type": "header",
      "content": "Button icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show arrow icon",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 10,
      "max": 32,
      "step": 1,
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Icon stroke width",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "App CTA"
    }
  ]
}
{% endschema %}
