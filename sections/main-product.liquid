{% assign current_product = product %}

<section
  class="product-detail-section min-h-screen bg-white pb-24"
  style="
    --pd-max-width: {{ section.settings.max_width }}px;
    --pd-top-padding: {{ section.settings.padding_top }}px;
    --pd-bottom-padding: {{ section.settings.padding_bottom }}px;
    --pd-gallery-gap: {{ section.settings.gallery_gap }}px;
    --pd-content-gap: {{ section.settings.content_gap }}px;
    --pd-thumb-columns: {{ section.settings.thumbnail_columns }};
    --pd-radius-main: {{ section.settings.image_radius }}px;
    --pd-radius-thumb: {{ section.settings.thumbnail_radius }}px;
    --pd-card-radius: {{ section.settings.card_radius }}px;
    --pd-border-color: {{ section.settings.border_color }};
    --pd-bg-light: {{ section.settings.light_bg }};
    --pd-heading-color: {{ section.settings.heading_color }};
    --pd-text-color: {{ section.settings.text_color }};
    --pd-muted-color: {{ section.settings.muted_color }};
    --pd-accent-color: {{ section.settings.accent_color }};
    --pd-button-bg: {{ section.settings.primary_button_bg }};
    --pd-button-text: {{ section.settings.primary_button_text }};
    --pd-secondary-button-bg: {{ section.settings.secondary_button_bg }};
    --pd-secondary-button-text: {{ section.settings.secondary_button_text }};
    --pd-pill-bg: {{ section.settings.badge_bg }};
    --pd-pill-text: {{ section.settings.badge_text }};
  "
>
  <div
    class="{% if section.settings.enable_container %}max-w-7xl mx-auto{% endif %} px-4 sm:px-6 lg:px-8"
    style="
      max-width: {% if section.settings.enable_container %}var(--pd-max-width){% else %}100%{% endif %};
      padding-top: var(--pd-top-padding);
      padding-bottom: var(--pd-bottom-padding);
    "
  >
    {% if section.settings.show_breadcrumb %}
      <a
        class="inline-flex items-center space-x-2 text-xs uppercase tracking-widest font-bold mb-10 transition-colors"
        href="{{ section.settings.breadcrumb_url | default: routes.collections_url }}"
        style="color: {{ section.settings.breadcrumb_color }}; font-size:{{- section.settings.breadcrumb_size -}}px"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        <span>{{ section.settings.breadcrumb_label }}</span>
      </a>
    {% endif %}

    <div
      class="!grid !grid-cols-1 {% if section.settings.desktop_layout == 'two_column' %}lg:!grid-cols-2{% else %}lg:!grid-cols-1{% endif %}"
      style="gap: var(--pd-content-gap);"
    >
      {% if section.settings.show_gallery %}
        <div class="space-y-4">
          <div
            class="aspect-square overflow-hidden border"
            style="
              border-radius: var(--pd-radius-main);
              background: var(--pd-bg-light);
              border-color: var(--pd-border-color);
            "
          >
            {% if current_product.featured_image %}
              <img
                src="{{ current_product.featured_image | image_url: width: section.settings.main_image_width }}"
                alt="{{ current_product.featured_image.alt | escape | default: current_product.title }}"
                class="w-full h-full object-cover"
                loading="eager"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
            {% endif %}
          </div>

          {% if section.settings.show_thumbnails and current_product.images.size > 1 %}
            <div
              class="!grid"
              style="grid-template-columns: repeat(var(--pd-thumb-columns), minmax(0, 1fr)); gap: {{ section.settings.thumbnail_gap }}px;"
            >
              {% for image in current_product.images limit: section.settings.thumbnail_limit %}
                <div
                  class="aspect-square overflow-hidden border cursor-pointer"
                  style="
                    border-radius: var(--pd-radius-thumb);
                    background: var(--pd-bg-light);
                    border-color: var(--pd-border-color);
                    opacity: {% if forloop.first %}1{% else %}{{ section.settings.inactive_thumb_opacity }}{% endif %};
                  "
                >
                  <img
                    src="{{ image | image_url: width: section.settings.thumbnail_width }}"
                    alt="{{ image.alt | escape | default: current_product.title }}"
                    class="w-full h-full object-cover"
                    loading="lazy"
                  >
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div>
        <div class="mb-8">
          {% if section.settings.show_vendor_or_category_badge %}
            <span
              class="inline-block px-3 py-1 text-[16px] font-bold uppercase tracking-widest mb-4 rounded"
              style="
                background: var(--pd-pill-bg);
                color: var(--pd-pill-text);
                border-radius: {{ section.settings.badge_radius }}px;
              "
            >
              {% if section.settings.badge_source == 'vendor_type' %}
                {{ current_product.vendor }}
                {% if current_product.type != blank %}
                  • {{ current_product.type }}
                {% endif %}
              {% elsif section.settings.badge_source == 'vendor' %}
                {{ current_product.vendor }}
              {% elsif section.settings.badge_source == 'type' %}
                {{ current_product.type }}
              {% elsif section.settings.badge_source == 'product_category' %}
                {{ current_product.category }}
              {% else %}
                {{ section.settings.custom_badge_text }}
              {% endif %}
            </span>
          {% endif %}

          {% if section.settings.show_title %}
            <h1
              class="leading-tight"
              style="
                color: var(--pd-heading-color);
                font-size: {{ section.settings.title_size }}px;
                font-weight: {{ section.settings.title_weight }};
                margin-bottom: {{ section.settings.title_margin_bottom }}px;
              "
            >
              {{ current_product.title }}
            </h1>
          {% endif %}

          {% if section.settings.show_sku %}
            {% assign first_variant = current_product.selected_or_first_available_variant %}
            <p
              class="uppercase tracking-widest font-mono"
              style="
                color: var(--pd-muted-color);
                font-size: {{ section.settings.sku_size }}px;
              "
            >
              {{ section.settings.sku_label }}:
              {{ first_variant.sku | default: section.settings.sku_fallback }}
            </p>
          {% endif %}
        </div>

        {% if section.settings.show_price %}
          <div class="mb-6">
            <div class="flex items-center gap-3 flex-wrap">
              <span
                style="
                  color: var(--pd-heading-color);
                  font-size: {{ section.settings.price_size }}px;
                  font-weight: {{ section.settings.price_weight }};
                "
              >
                {{ first_variant.price | money }}
              </span>

              {% if first_variant.compare_at_price > first_variant.price and section.settings.show_compare_price %}
                <span
                  style="
                    color: var(--pd-muted-color);
                    font-size: {{ section.settings.compare_price_size }}px;
                    text-decoration: line-through;
                  "
                >
                  {{ first_variant.compare_at_price | money }}
                </span>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if section.settings.show_description %}
          <div
            class="prose prose-stone mb-10"
            style="
              color: var(--pd-text-color);
              font-size: {{ section.settings.description_size }}px;
            "
          >
            {% if section.settings.description_source == 'product_description' %}
              {{ current_product.description }}
            {% elsif section.settings.description_source == 'short_description_metafield' %}
              {{ current_product.metafields.custom.short_description | metafield_tag }}
            {% else %}
              {{ current_product.description }}
            {% endif %}
          </div>
        {% endif %}

        {% if section.settings.show_variant_picker and current_product.has_only_default_variant == false %}
          <div class="mb-8">
            {% for option in current_product.options_with_values %}
              <div class="mb-5">
                <label
                  class="block mb-2 font-bold uppercase tracking-widest"
                  style="
                    color: var(--pd-heading-color);
                    font-size: {{ section.settings.option_label_size }}px;
                  "
                >
                  {{ option.name }}
                </label>

                <div class="flex flex-wrap gap-2">
                  {% for value in option.values %}
                    <span
                      class="inline-flex items-center justify-center border"
                      style="
                        padding: {{ section.settings.option_chip_y }}px {{ section.settings.option_chip_x }}px;
                        border-radius: {{ section.settings.option_chip_radius }}px;
                        border-color: var(--pd-border-color);
                        color: var(--pd-heading-color);
                        background: {{ section.settings.option_chip_bg }};
                        font-size: {{ section.settings.option_chip_text_size }}px;
                      "
                    >
                      {{ value }}
                    </span>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.show_feature_cards %}
          <div class="!grid !grid-cols-1 sm:!grid-cols-2 gap-4 mb-10">
            {% for block in section.blocks %}
              {% if block.type == 'feature_card' %}
                <div
                  class="p-4 border flex items-start space-x-3"
                  style="
                    background: var(--pd-bg-light);
                    border-radius: var(--pd-card-radius);
                    border-color: var(--pd-border-color);
                  "
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.icon_svg != blank %}
                    <div
                      class="shrink-0"
                      style="color: var(--pd-accent-color); width: {{ block.settings.icon_size }}px;"
                    >
                      {{ block.settings.icon_svg }}
                    </div>
                  {% endif %}
                  <div>
                    <h4
                      class="font-bold"
                      style="
                        color: var(--pd-heading-color);
                        font-size: {{ block.settings.title_size }}px;
                        margin-bottom: 4px;
                      "
                    >
                      {{ block.settings.title }}
                    </h4>
                    <p
                      style="
                        color: var(--pd-muted-color);
                        font-size: {{ block.settings.text_size }}px;
                      "
                    >
                      {{ block.settings.text }}
                    </p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% assign bim_file = current_product.metafields.custom.bim_file %}
        {% assign tech_sheet = current_product.metafields.custom.technical_data_sheet %}

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <button
            type="button"
            class="flex-1 font-bold flex items-center justify-center space-x-3 transition-all js-ajax-add-to-cart"
            data-variant-id="{{ current_variant.id }}"
            style="
              padding-top: {{ section.settings.button_y_padding }}px;
              padding-bottom: {{ section.settings.button_y_padding }}px;
              padding-left: {{ section.settings.button_x_padding }}px;
              padding-right: {{ section.settings.button_x_padding }}px;
              border-radius: {{ section.settings.button_radius }}px;
              background: var(--pd-button-bg);
              color: var(--pd-button-text);
            "
          >
            <span class="js-add-to-cart-text">Add to cart</span>
          </button>

          {% if bim_file != blank %}
            <a
              href="{{ bim_file.value }}"
              class="font-bold flex items-center justify-center space-x-3 border"
              style="
                padding-top: {{ section.settings.button_y_padding }}px;
                padding-bottom: {{ section.settings.button_y_padding }}px;
                padding-left: {{ section.settings.button_x_padding }}px;
                padding-right: {{ section.settings.button_x_padding }}px;
                border-radius: {{ section.settings.button_radius }}px;
                background: var(--pd-secondary-button-bg);
                color: var(--pd-secondary-button-text);
                border-color: var(--pd-border-color);
              "
              {% if section.settings.secondary_button_new_tab %}
                target="_blank"
              {% endif %}
              rel="noopener noreferrer"
            >
              <span>Download BIM File</span>
            </a>
          {% endif %}

          {% if tech_sheet != blank %}
            <a
              href="{{ tech_sheet.value }}"
              class="font-bold flex items-center justify-center space-x-3 border"
              style="
                padding-top: {{ section.settings.button_y_padding }}px;
                padding-bottom: {{ section.settings.button_y_padding }}px;
                padding-left: {{ section.settings.button_x_padding }}px;
                padding-right: {{ section.settings.button_x_padding }}px;
                border-radius: {{ section.settings.button_radius }}px;
                background: var(--pd-secondary-button-bg);
                color: var(--pd-secondary-button-text);
                border-color: var(--pd-border-color);
              "
              download
              {% if section.settings.secondary_button_new_tab %}
                target="_blank"
              {% endif %}
              rel="noopener noreferrer"
            >
              <span>Download Technical Data Sheet</span>
            </a>
          {% endif %}
        </div>

        {% if section.settings.show_specifications %}
          <div class="border-t pt-8" style="border-color: var(--pd-border-color);">
            <h4
              class="font-bold uppercase tracking-widest mb-6 flex items-center space-x-2"
              style="
                color: var(--pd-heading-color);
                font-size: {{ section.settings.spec_heading_size }}px;
              "
            >
              <span>{{ section.settings.spec_heading }}</span>
            </h4>

            <div class="space-y-4">
              {% if section.settings.show_material_row %}
                {% assign spec_material = current_product.metafields.shopify.material.value %}
                {% if spec_material != blank %}
                  <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                    <span style="color: var(--pd-muted-color);">{{ section.settings.material_label }}</span>
                    <span class="font-medium" style="color: var(--pd-heading-color);">{{ spec_material }}</span>
                  </div>
                {% endif %}
              {% endif %}

              {% if section.settings.show_finish_row %}
                {% assign spec_finish = current_product.metafields.shopify['color-pattern'].value %}
                {% if spec_finish != blank %}
                  <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                    <span style="color: var(--pd-muted-color);">{{ section.settings.finish_label }}</span>
                    <span class="font-medium" style="color: var(--pd-heading-color);">{{ spec_finish }}</span>
                  </div>
                {% endif %}
              {% endif %}

              {% if section.settings.show_mounting_row %}
                {% assign spec_mounting = current_product.metafields.shopify['mounting-type'].value %}
                {% if spec_mounting != blank %}
                  <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                    <span style="color: var(--pd-muted-color);">{{ section.settings.mounting_label }}</span>
                    <span class="font-medium" style="color: var(--pd-heading-color);">{{ spec_mounting }}</span>
                  </div>
                {% endif %}
              {% endif %}

              {% if section.settings.show_shape_row %}
                {% assign spec_shape = current_product.metafields.shopify.shape.value %}
                {% if spec_shape != blank %}
                  <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                    <span style="color: var(--pd-muted-color);">{{ section.settings.shape_label }}</span>
                    <span class="font-medium" style="color: var(--pd-heading-color);">{{ spec_shape }}</span>
                  </div>
                {% endif %}
              {% endif %}

              {% if section.settings.show_location_row %}
                {% assign spec_location = current_product.metafields.shopify['suitable-location'].value %}
                {% if spec_location != blank %}
                  <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                    <span style="color: var(--pd-muted-color);">{{ section.settings.location_label }}</span>
                    <span class="font-medium" style="color: var(--pd-heading-color);">{{ spec_location }}</span>
                  </div>
                {% endif %}
              {% endif %}

              {% if section.settings.show_custom_spec_1
                and section.settings.custom_spec_1_label != blank
                and section.settings.custom_spec_1_value != blank
              %}
                <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                  <span style="color: var(--pd-muted-color);">{{ section.settings.custom_spec_1_label }}</span>
                  <span class="font-medium" style="color: var(--pd-heading-color);">
                    {{- section.settings.custom_spec_1_value -}}
                  </span>
                </div>
              {% endif %}

              {% if section.settings.show_custom_spec_2
                and section.settings.custom_spec_2_label != blank
                and section.settings.custom_spec_2_value != blank
              %}
                <div class="flex justify-between text-sm py-2 border-b" style="border-color: var(--pd-border-color);">
                  <span style="color: var(--pd-muted-color);">{{ section.settings.custom_spec_2_label }}</span>
                  <span class="font-medium" style="color: var(--pd-heading-color);">
                    {{- section.settings.custom_spec_2_value -}}
                  </span>
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if section.settings.show_downloads %}
          <div class="mt-10">
            <h4
              class="font-bold uppercase tracking-widest mb-4"
              style="
                color: var(--pd-heading-color);
                font-size: {{ section.settings.download_heading_size }}px;
              "
            >
              {{ section.settings.download_heading }}
            </h4>

            <div class="flex flex-wrap gap-3">
              {% assign bim_file = current_product.metafields.custom.bim_file %}
              {% assign tech_sheet = current_product.metafields.custom.technical_data_sheet %}

              {% if section.settings.show_bim_download and bim_file != blank %}
                <a
                  href="{{ bim_file.value }}"
                  class="inline-flex items-center justify-center border"
                  style="
                    padding: {{ section.settings.download_btn_y }}px {{ section.settings.download_btn_x }}px;
                    border-radius: {{ section.settings.download_btn_radius }}px;
                    border-color: var(--pd-border-color);
                    color: var(--pd-heading-color);
                    background: {{ section.settings.download_btn_bg }};
                  "
                  target="_blank"
                >
                  {{ section.settings.bim_button_label }}
                </a>
              {% endif %}

              {% if section.settings.show_tech_sheet_download and tech_sheet != blank %}
                <a
                  href="{{ tech_sheet.value }}"
                  class="inline-flex items-center justify-center border"
                  style="
                    padding: {{ section.settings.download_btn_y }}px {{ section.settings.download_btn_x }}px;
                    border-radius: {{ section.settings.download_btn_radius }}px;
                    border-color: var(--pd-border-color);
                    color: var(--pd-heading-color);
                    background: {{ section.settings.download_btn_bg }};
                  "
                  target="_blank"
                >
                  {{ section.settings.tech_sheet_button_label }}
                </a>
              {% endif %}

              {% comment %}
                UNUSED / OPTIONAL:
                Attachment type metafield can be surfaced here later if you want grouped download buttons by file type.
              {% endcomment %}
            </div>
          </div>
        {% endif %}

        {% comment %}
          UNUSED / OPTIONAL SECTIONS:
          1. Inventory meter
          2. Quantity selector
          3. Add to cart form
          4. Related products
          5. Sticky buy bar
          6. Accordion tabs for description/specs/downloads
          7. Variant image swap JS
        {% endcomment %}
      </div>
    </div>
  </div>
</section>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const addToCartBtn = document.querySelector('.js-ajax-add-to-cart');

    if (!addToCartBtn) return;

    addToCartBtn.addEventListener('click', async function () {
      const variantId = this.dataset.variantId;
      const buttonText = this.querySelector('.js-add-to-cart-text');
      const originalText = buttonText ? buttonText.textContent : 'Add to cart';

      try {
        this.disabled = true;
        if (buttonText) buttonText.textContent = 'Adding...';

        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        });

        if (!response.ok) {
          throw new Error('Failed to add product to cart');
        }

        const data = await response.json();

        if (buttonText) buttonText.textContent = 'Added';

        document.documentElement.dispatchEvent(
          new CustomEvent('cart:updated', {
            detail: { product: data }
          })
        );

        setTimeout(() => {
          if (buttonText) buttonText.textContent = originalText;
          this.disabled = false;
        }, 1200);

      } catch (error) {
        console.error(error);
        if (buttonText) buttonText.textContent = 'Error';
        setTimeout(() => {
          if (buttonText) buttonText.textContent = originalText;
          this.disabled = false;
        }, 1500);
      }
    });
  });
</script>


{% schema %}
{
  "name": "Advanced Product Detail",
  "tag": "section",
  "class": "section advanced-product-detail",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "enable_container", "label": "Enable container", "default": true },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "default": 1280,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "default": "two_column",
      "options": [
        { "value": "two_column", "label": "Two column" },
        { "value": "single_column", "label": "Single column" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Column gap",
      "min": 12,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gallery_gap",
      "label": "Gallery gap",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 16,
      "unit": "px"
    },

    { "type": "header", "content": "Breadcrumb" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb/back link", "default": true },
    { "type": "text", "id": "breadcrumb_label", "label": "Breadcrumb label", "default": "Back to Catalog" },
    { "type": "url", "id": "breadcrumb_url", "label": "Breadcrumb URL" },
    { "type": "color", "id": "breadcrumb_color", "label": "Breadcrumb color", "default": "#64748b" },
    { "type": "number", "id": "breadcrumb_size", "label": "Breadcrumb Size", "default": 18 },

    { "type": "header", "content": "Gallery" },
    { "type": "checkbox", "id": "show_gallery", "label": "Show gallery", "default": true },
    { "type": "checkbox", "id": "show_thumbnails", "label": "Show thumbnails", "default": true },
    {
      "type": "range",
      "id": "thumbnail_columns",
      "label": "Thumbnail columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "thumbnail_gap",
      "label": "Thumbnail gap",
      "min": 4,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "thumbnail_limit",
      "label": "Thumbnail limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "main_image_width",
      "label": "Main image render width",
      "min": 600,
      "max": 2400,
      "step": 100,
      "default": 1400
    },
    {
