<div class="min-h-screen bg-white pb-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
    <a
      class="inline-flex items-center space-x-2 text-xs uppercase tracking-widest font-bold text-brand-primary/40 hover:text-brand-accent mb-10 transition-colors"
      href="/shop"
      data-discover="true"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-chevron-left"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      <span>Back to Catalog</span></a
    >
    <div class="!grid !grid-cols-1 lg:!grid-cols-2 gap-16">
      <div class="space-y-4">
        <div class="aspect-square rounded-3xl overflow-hidden bg-stone-50 border border-black/5">
          <img
            alt="Bobrick B-2892 Surface-Mounted Twin Jumbo-Roll Toilet Tissue Dispenser"
            class="w-full h-full object-cover"
            referrerpolicy="no-referrer"
            src="https://picsum.photos/seed/toilet-dispenser/600/600"
          >
        </div>
        <div class="!grid !grid-cols-4 gap-4">
          <div
            class="aspect-square rounded-xl overflow-hidden bg-stone-50 border border-black/5 opacity-60 hover:opacity-100 transition-opacity cursor-pointer"
          >
            <img
              alt="Gallery"
              class="w-full h-full object-cover"
              referrerpolicy="no-referrer"
              src="https://picsum.photos/seed/detail-1/300/300"
            >
          </div>
          <div
            class="aspect-square rounded-xl overflow-hidden bg-stone-50 border border-black/5 opacity-60 hover:opacity-100 transition-opacity cursor-pointer"
          >
            <img
              alt="Gallery"
              class="w-full h-full object-cover"
              referrerpolicy="no-referrer"
              src="https://picsum.photos/seed/detail-2/300/300"
            >
          </div>
          <div
            class="aspect-square rounded-xl overflow-hidden bg-stone-50 border border-black/5 opacity-60 hover:opacity-100 transition-opacity cursor-pointer"
          >
            <img
              alt="Gallery"
              class="w-full h-full object-cover"
              referrerpolicy="no-referrer"
              src="https://picsum.photos/seed/detail-3/300/300"
            >
          </div>
          <div
            class="aspect-square rounded-xl overflow-hidden bg-stone-50 border border-black/5 opacity-60 hover:opacity-100 transition-opacity cursor-pointer"
          >
            <img
              alt="Gallery"
              class="w-full h-full object-cover"
              referrerpolicy="no-referrer"
              src="https://picsum.photos/seed/detail-4/300/300"
            >
          </div>
        </div>
      </div>
      <div>
        <div class="mb-8">
          <span
            class="inline-block px-3 py-1 bg-stone-100 text-brand-primary text-[10px] font-bold uppercase tracking-widest mb-4 rounded"
            >Bobrick • Toilet Partition Accessories</span
          >
          <h1 class="text-4xl font-bold mb-4 leading-tight">
            Bobrick B-2892 Surface-Mounted Twin Jumbo-Roll Toilet Tissue Dispenser
          </h1>
          <p class="text-sm text-brand-primary/40 uppercase tracking-widest font-mono">SKU: B-2892</p>
        </div>
        <div class="prose prose-stone mb-10">
          <p class="text-lg text-brand-primary/70 leading-relaxed">
            Satin-finish stainless steel. Equipped with tumbler lock. Spindles hold two 10" (255mm) diameter rolls with
            2-1/4" (55mm) diameter core.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
          <div class="p-4 bg-stone-50 rounded-2xl border border-black/5 flex items-start space-x-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-shield text-brand-accent mt-1"
              aria-hidden="true"
            >
              <path
                d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z">
              </path>
            </svg>
            <div>
              <h4 class="font-bold text-sm">ADA Compliant</h4>
              <p class="text-xs text-brand-primary/50">Meets all commercial accessibility standards.</p>
            </div>
          </div>
          <div class="p-4 bg-stone-50 rounded-2xl border border-black/5 flex items-start space-x-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-truck text-brand-accent mt-1"
              aria-hidden="true"
            >
              <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
              <path d="M15 18H9"></path>
              <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path>
              <circle cx="17" cy="18" r="2"></circle>
              <circle cx="7" cy="18" r="2"></circle>
            </svg>
            <div>
              <h4 class="font-bold text-sm">In Stock</h4>
              <p class="text-xs text-brand-primary/50">Ready for immediate nationwide shipping.</p>
            </div>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <button
            class="flex-1 py-5 rounded-full font-bold flex items-center justify-center space-x-3 transition-all bg-brand-primary text-white hover:bg-brand-primary/90"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-shopping-cart"
              aria-hidden="true"
            >
              <circle cx="8" cy="21" r="1"></circle>
              <circle cx="19" cy="21" r="1"></circle>
              <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
            </svg>
            <span>Add to Quote Request</span></button
          ><a
            href="#"
            class="px-8 py-5 border border-black/10 rounded-full font-bold flex items-center justify-center space-x-3 hover:bg-stone-50 transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-file-down"
              aria-hidden="true"
            >
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
              <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
              <path d="M12 18v-6"></path>
              <path d="m9 15 3 3 3-3"></path>
            </svg>
            <span>Download Spec Sheet</span></a
          >
        </div>
        <div class="border-t border-black/5 pt-8">
          <h4 class="font-bold text-sm uppercase tracking-widest mb-6 flex items-center space-x-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-info text-brand-accent"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 16v-4"></path>
              <path d="M12 8h.01"></path>
            </svg>
            <span>Product Specifications</span>
          </h4>
          <div class="space-y-4">
            <div class="flex justify-between text-sm py-2 border-b border-black/5">
              <span
                class="text-brand-primary/50"
                >Material</span
              ><span class="font-medium">Type 304 Stainless Steel</span>
            </div>
            <div class="flex justify-between text-sm py-2 border-b border-black/5">
              <span
                class="text-brand-primary/50"
                >Finish</span
              ><span class="font-medium">Satin Finish</span>
            </div>
            <div class="flex justify-between text-sm py-2 border-b border-black/5">
              <span
                class="text-brand-primary/50"
                >Mounting</span
              ><span class="font-medium">Surface Mounted</span>
            </div>
            <div class="flex justify-between text-sm py-2 border-b border-black/5">
              <span
                class="text-brand-primary/50"
                >Warranty</span
              ><span class="font-medium">1 Year Limited</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "blocks": [],
  "settings": []
}
{% endschema %}
