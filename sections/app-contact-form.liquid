<section class="py04">
  <div class="section-width mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="!grid !grid-cols-1 lg:!grid-cols-2 gap-10"
      style="column-gap: {{ section.settings.columns_gap }}px; row-gap: {{ section.settings.rows_gap }}px;"
    >
      <div>
        {% if section.settings.left_heading != blank %}
          <h2
            class="text-3xl font-bold mb-10"
            style="
              color: {{ section.settings.left_heading_color }};
              font-size: {{ section.settings.left_heading_size }}px;
              font-weight: {{ section.settings.left_heading_weight }};
              line-height: {{ section.settings.left_heading_line_height }};
              letter-spacing: {{ section.settings.left_heading_letter_spacing }}px;
              margin-bottom: {{ section.settings.left_heading_margin_bottom }}px;
              text-align: {{ section.settings.left_heading_align }};
              text-transform: {% if section.settings.left_heading_uppercase %}uppercase{% else %}none{% endif %};
            "
          >
            {{ section.settings.left_heading }}
          </h2>
        {% endif %}

        <div class="space-y-12">
          {% for block in section.blocks %}
            {% if block.type == 'contact_item' %}
              {% assign icon_bg_alpha = block.settings.icon_bg_opacity | times: 0.01 %}
              {% assign item_border_alpha = block.settings.item_border_opacity | times: 0.01 %}

              <div
                class="flex items-start space-x-6 space-y-8"
                {{ block.shopify_attributes }}
                style="
                  column-gap: {{ block.settings.item_gap }}px;
                  margin-bottom: {{ block.settings.item_margin_bottom }}px;
                  padding-top: {{ block.settings.item_padding_top }}px;
                  padding-right: {{ block.settings.item_padding_right }}px;
                  padding-bottom: {{ block.settings.item_padding_bottom }}px;
                  padding-left: {{ block.settings.item_padding_left }}px;
                  border-radius: {{ block.settings.item_radius }}px;
                  border: {{ block.settings.item_border_width }}px solid rgba({{ block.settings.item_border_color.red }}, {{ block.settings.item_border_color.green }}, {{ block.settings.item_border_color.blue }}, {{ item_border_alpha }});
                  text-align: {{ block.settings.text_align }};
                  justify-content:
                    {% case block.settings.item_horizontal_alignment %}
                      {% when 'left' %}flex-start
                      {% when 'center' %}center
                      {% when 'right' %}flex-end
                    {% endcase %};
                "
              >
                {% if block.settings.show_icon %}
                  <div
                    class="p-4 bg-stone-100 rounded0xl text-brand-accent"
                    style="
                      padding: {{ block.settings.icon_box_padding }}px;
                      border-radius: {{ block.settings.icon_box_radius }}px;
                      color: {{ block.settings.icon_color }};
                      background: rgba({{ block.settings.icon_bg_color.red }}, {{ block.settings.icon_bg_color.green }}, {{ block.settings.icon_bg_color.blue }}, {{ icon_bg_alpha }});
                      flex-shrink: 0;
                    "
                  >
                    {% if block.settings.custom_icon_svg != blank %}
                      <span
                        style="
                          display: inline-flex;
                          width: {{ block.settings.icon_width }}px;
                          height: {{ block.settings.icon_height }}px;
                          opacity: {{ block.settings.icon_opacity | times: 0.01 }};
                        "
                      >
                        {{ block.settings.custom_icon_svg }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                <div>
                  {% if block.settings.title != blank %}
                    <h4
                      class="text-lg font-bold mb-1"
                      style="
                        color: {{ block.settings.title_color }};
                        font-size: {{ block.settings.title_size }}px;
                        font-weight: {{ block.settings.title_weight }};
                        line-height: {{ block.settings.title_line_height }};
                        letter-spacing: {{ block.settings.title_letter_spacing }}px;
                        margin-bottom: {{ block.settings.title_margin_bottom }}px;
                        text-transform: {% if block.settings.title_uppercase %}uppercase{% else %}none{% endif %};
                      "
                    >
                      {{ block.settings.title }}
                    </h4>
                  {% endif %}

                  {% if block.settings.description != blank %}
                    <p
                      class="text-brand-primary/60 mb0"
                      style="
                        color: {{ block.settings.description_color }};
                        font-size: {{ block.settings.description_size }}px;
                        font-weight: {{ block.settings.description_weight }};
                        line-height: {{ block.settings.description_line_height }};
                        letter-spacing: {{ block.settings.description_letter_spacing }}px;
                        margin-bottom: {{ block.settings.description_margin_bottom }}px;
                      "
                    >
                      {{ block.settings.description }}
                    </p>
                  {% endif %}

                  {% if block.settings.display_mode == 'link'
                    and block.settings.link_text != blank
                    and block.settings.link_url != blank
                  %}
                    <a
                      href="{{ block.settings.link_url }}"
                      class="text-xl font-bold hover:text-brand-accent transition-colors"
                      style="
                        color: {{ block.settings.value_color }};
                        font-size: {{ block.settings.value_size }}px;
                        font-weight: {{ block.settings.value_weight }};
                        line-height: {{ block.settings.value_line_height }};
                        letter-spacing: {{ block.settings.value_letter_spacing }}px;
                        text-transform: {% if block.settings.value_uppercase %}uppercase{% else %}none{% endif %};
                      "
                    >
                      {{ block.settings.link_text }}
                    </a>
                  {% elsif block.settings.display_mode == 'text' and block.settings.value_text != blank %}
                    <p
                      class="text-xl font-bold"
                      style="
                        color: {{ block.settings.value_color }};
                        font-size: {{ block.settings.value_size }}px;
                        font-weight: {{ block.settings.value_weight }};
                        line-height: {{ block.settings.value_line_height }};
                        letter-spacing: {{ block.settings.value_letter_spacing }}px;
                        margin: 0;
                        text-transform: {% if block.settings.value_uppercase %}uppercase{% else %}none{% endif %};
                      "
                    >
                      {{ block.settings.value_text }}
                    </p>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% assign form_bg_alpha = section.settings.form_card_bg_opacity | times: 0.01 %}
      {% assign form_border_alpha = section.settings.form_card_border_opacity | times: 0.01 %}
      {% assign input_bg_alpha = section.settings.input_bg_opacity | times: 0.01 %}
      {% assign input_border_alpha = section.settings.input_border_opacity | times: 0.01 %}
      {% assign button_shadow_alpha = section.settings.button_shadow_opacity | times: 0.01 %}

      <div
        class="bg-stone-50 p-10 md:p-16 rounded-[3rem] border border-black/5"
        style="
          background: rgba({{ section.settings.form_card_bg_color.red }}, {{ section.settings.form_card_bg_color.green }}, {{ section.settings.form_card_bg_color.blue }}, {{ form_bg_alpha }});
          padding-top: {{ section.settings.form_card_padding_top }}px;
          padding-right: {{ section.settings.form_card_padding_right }}px;
          padding-bottom: {{ section.settings.form_card_padding_bottom }}px;
          padding-left: {{ section.settings.form_card_padding_left }}px;
          border-radius: {{ section.settings.form_card_radius }}px;
          border-width: {{ section.settings.form_card_border_width }}px;
          border-style: solid;
          border-color: rgba({{ section.settings.form_card_border_color.red }}, {{ section.settings.form_card_border_color.green }}, {{ section.settings.form_card_border_color.blue }}, {{ form_border_alpha }});
        "
      >
        {% if section.settings.form_heading != blank %}
          <h3
            class="text0xl font-bold mb-8"
            style="
              color: {{ section.settings.form_heading_color }};
              font-size: {{ section.settings.form_heading_size }}px;
              font-weight: {{ section.settings.form_heading_weight }};
              line-height: {{ section.settings.form_heading_line_height }};
              letter-spacing: {{ section.settings.form_heading_letter_spacing }}px;
              margin-bottom: {{ section.settings.form_heading_margin_bottom }}px;
              text-transform: {% if section.settings.form_heading_uppercase %}uppercase{% else %}none{% endif %};
            "
          >
            {{ section.settings.form_heading }}
          </h3>
        {% endif %}

        <form
          class="space-y-6"
          action="{{ section.settings.form_action }}"
          method="{{ section.settings.form_method }}"
        >
          <div class="space-y0">
            <label
              class="text-xs font-bold uppercase tracking-widest text-brand-primary/50"
              style="
                color: {{ section.settings.label_color }};
                font-size: {{ section.settings.label_size }}px;
                font-weight: {{ section.settings.label_weight }};
                letter-spacing: {{ section.settings.label_letter_spacing }}px;
                line-height: {{ section.settings.label_line_height }};
                text-transform: {% if section.settings.label_uppercase %}uppercase{% else %}none{% endif %};
              "
            >
              {{ section.settings.name_label }}
            </label>
            <input
              name="{{ section.settings.name_field_name }}"
              {% if section.settings.name_required %}
                required
              {% endif %}
              class="w-full px-6 py-4 bg-white border border-black/5 rounded0xl focus:outline-none focus:ring0 focus:ring-brand-accent/50 transition-all"
              placeholder="{{ section.settings.name_placeholder }}"
              type="text"
              style="
                color: {{ section.settings.input_text_color }};
                background: rgba({{ section.settings.input_bg_color.red }}, {{ section.settings.input_bg_color.green }}, {{ section.settings.input_bg_color.blue }}, {{ input_bg_alpha }});
                border-width: {{ section.settings.input_border_width }}px;
                border-style: solid;
                border-color: rgba({{ section.settings.input_border_color.red }}, {{ section.settings.input_border_color.green }}, {{ section.settings.input_border_color.blue }}, {{ input_border_alpha }});
                border-radius: {{ section.settings.input_radius }}px;
                padding-top: {{ section.settings.input_padding_y }}px;
                padding-bottom: {{ section.settings.input_padding_y }}px;
                padding-left: {{ section.settings.input_padding_x }}px;
                padding-right: {{ section.settings.input_padding_x }}px;
                font-size: {{ section.settings.input_text_size }}px;
                font-weight: {{ section.settings.input_text_weight }};
                line-height: {{ section.settings.input_text_line_height }};
              "
            >
          </div>

          <div class="space-y0">
            <label
              class="text-xs font-bold uppercase tracking-widest text-brand-primary/50"
              style="
                color: {{ section.settings.label_color }};
                font-size: {{ section.settings.label_size }}px;
                font-weight: {{ section.settings.label_weight }};
                letter-spacing: {{ section.settings.label_letter_spacing }}px;
                line-height: {{ section.settings.label_line_height }};
                text-transform: {% if section.settings.label_uppercase %}uppercase{% else %}none{% endif %};
              "
            >
              {{ section.settings.email_label }}
            </label>
            <input
              name="{{ section.settings.email_field_name }}"
              {% if section.settings.email_required %}
                required
              {% endif %}
              class="w-full px-6 py-4 bg-white border border-black/5 rounded0xl focus:outline-none focus:ring0 focus:ring-brand-accent/50 transition-all"
              placeholder="{{ section.settings.email_placeholder }}"
              type="email"
              style="
                color: {{ section.settings.input_text_color }};
                background: rgba({{ section.settings.input_bg_color.red }}, {{ section.settings.input_bg_color.green }}, {{ section.settings.input_bg_color.blue }}, {{ input_bg_alpha }});
                border-width: {{ section.settings.input_border_width }}px;
                border-style: solid;
                border-color: rgba({{ section.settings.input_border_color.red }}, {{ section.settings.input_border_color.green }}, {{ section.settings.input_border_color.blue }}, {{ input_border_alpha }});
                border-radius: {{ section.settings.input_radius }}px;
                padding-top: {{ section.settings.input_padding_y }}px;
                padding-bottom: {{ section.settings.input_padding_y }}px;
                padding-left: {{ section.settings.input_padding_x }}px;
                padding-right: {{ section.settings.input_padding_x }}px;
                font-size: {{ section.settings.input_text_size }}px;
                font-weight: {{ section.settings.input_text_weight }};
                line-height: {{ section.settings.input_text_line_height }};
              "
            >
          </div>

          <div class="space-y0">
            <label
              class="text-xs font-bold uppercase tracking-widest text-brand-primary/50"
              style="
                color: {{ section.settings.label_color }};
                font-size: {{ section.settings.label_size }}px;
                font-weight: {{ section.settings.label_weight }};
                letter-spacing: {{ section.settings.label_letter_spacing }}px;
                line-height: {{ section.settings.label_line_height }};
                text-transform: {% if section.settings.label_uppercase %}uppercase{% else %}none{% endif %};
              "
            >
              {{ section.settings.subject_label }}
            </label>
            <select
              name="{{ section.settings.subject_field_name }}"
              class="w-full px-6 py-4 bg-white border border-black/5 rounded0xl focus:outline-none focus:ring0 focus:ring-brand-accent/50 transition-all"
              style="
                color: {{ section.settings.input_text_color }};
                background: rgba({{ section.settings.input_bg_color.red }}, {{ section.settings.input_bg_color.green }}, {{ section.settings.input_bg_color.blue }}, {{ input_bg_alpha }});
                border-width: {{ section.settings.input_border_width }}px;
                border-style: solid;
                border-color: rgba({{ section.settings.input_border_color.red }}, {{ section.settings.input_border_color.green }}, {{ section.settings.input_border_color.blue }}, {{ input_border_alpha }});
                border-radius: {{ section.settings.input_radius }}px;
                padding-top: {{ section.settings.input_padding_y }}px;
                padding-bottom: {{ section.settings.input_padding_y }}px;
                padding-left: {{ section.settings.input_padding_x }}px;
                padding-right: {{ section.settings.input_padding_x }}px;
                font-size: {{ section.settings.input_text_size }}px;
                font-weight: {{ section.settings.input_text_weight }};
                line-height: {{ section.settings.input_text_line_height }};
              "
            >
              {% for block in section.blocks %}
                {% if block.type == 'subject_option' %}
                  <option value="{{ block.settings.option_value | escape }}">
                    {{ block.settings.option_label }}
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          </div>

          <div class="space-y0">
            <label
              class="text-xs font-bold uppercase tracking-widest text-brand-primary/50"
              style="
                color: {{ section.settings.label_color }};
                font-size: {{ section.settings.label_size }}px;
                font-weight: {{ section.settings.label_weight }};
                letter-spacing: {{ section.settings.label_letter_spacing }}px;
                line-height: {{ section.settings.label_line_height }};
                text-transform: {% if section.settings.label_uppercase %}uppercase{% else %}none{% endif %};
              "
            >
              {{ section.settings.message_label }}
            </label>
            <textarea
              name="{{ section.settings.message_field_name }}"
              {% if section.settings.message_required %}
                required
              {% endif %}
              rows="{{ section.settings.message_rows }}"
              class="w-full px-6 py-4 bg-white border border-black/5 rounded0xl focus:outline-none focus:ring0 focus:ring-brand-accent/50 transition-all resize-none"
              placeholder="{{ section.settings.message_placeholder }}"
              style="
                color: {{ section.settings.input_text_color }};
                background: rgba({{ section.settings.input_bg_color.red }}, {{ section.settings.input_bg_color.green }}, {{ section.settings.input_bg_color.blue }}, {{ input_bg_alpha }});
                border-width: {{ section.settings.input_border_width }}px;
                border-style: solid;
                border-color: rgba({{ section.settings.input_border_color.red }}, {{ section.settings.input_border_color.green }}, {{ section.settings.input_border_color.blue }}, {{ input_border_alpha }});
                border-radius: {{ section.settings.input_radius }}px;
                padding-top: {{ section.settings.input_padding_y }}px;
                padding-bottom: {{ section.settings.input_padding_y }}px;
                padding-left: {{ section.settings.input_padding_x }}px;
                padding-right: {{ section.settings.input_padding_x }}px;
                font-size: {{ section.settings.input_text_size }}px;
                font-weight: {{ section.settings.input_text_weight }};
                line-height: {{ section.settings.input_text_line_height }};
              "
            ></textarea>
          </div>

          {% if section.settings.show_button %}
            <button
              type="submit"
              class="w-full py-5 bg-brand-primary text-white font-bold rounded-full flex items-center justify-center space-x-3 hover:bg-brand-primary/90 transition-all shadow-lg"
              style="
                background: {{ section.settings.button_bg_color }};
                color: {{ section.settings.button_text_color }};
                border-radius: {{ section.settings.button_radius }}px;
                padding-top: {{ section.settings.button_padding_y }}px;
                padding-bottom: {{ section.settings.button_padding_y }}px;
                padding-left: {{ section.settings.button_padding_x }}px;
                padding-right: {{ section.settings.button_padding_x }}px;
                font-size: {{ section.settings.button_text_size }}px;
                font-weight: {{ section.settings.button_text_weight }};
                letter-spacing: {{ section.settings.button_letter_spacing }}px;
                box-shadow: 0 12px 30px rgba({{ section.settings.button_shadow_color.red }}, {{ section.settings.button_shadow_color.green }}, {{ section.settings.button_shadow_color.blue }}, {{ button_shadow_alpha }});
                column-gap: {{ section.settings.button_gap }}px;
                text-transform: {% if section.settings.button_uppercase %}uppercase{% else %}none{% endif %};
              "
            >
              <span>{{ section.settings.button_text }}</span>

              {% if section.settings.button_icon_svg != blank %}
                <span
                  style="
                    display: inline-flex;
                    width: {{ section.settings.button_icon_width }}px;
                    height: {{ section.settings.button_icon_height }}px;
                  "
                >
                  {{ section.settings.button_icon_svg }}
                </span>
              {% endif %}
            </button>
          {% endif %}
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .section-width{
    width:100%;
    max-width:{{section.settings.section_width }}px;
  }
</style>

{% schema %}
{
  "name": "App Contact Form",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "number",
      "id": "section_width",
      "label": "Max Width",
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Columns gap",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "Rows gap",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 80
    },

    {
      "type": "header",
      "content": "Left heading"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "color",
      "id": "left_heading_color",
      "label": "Heading color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "left_heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "left_heading_weight",
      "label": "Heading weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" },
        { "value": "900", "label": "900" }
      ]
    },
    {
      "type": "range",
      "id": "left_heading_line_height",
      "label": "Heading line height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "left_heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "left_heading_margin_bottom",
      "label": "Heading bottom spacing",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "left_heading_align",
      "label": "Heading alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "left_heading_uppercase",
      "label": "Uppercase heading",
      "default": false
    },

    {
      "type": "header",
      "content": "Form card"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Send a Message"
    },
    {
      "type": "color",
      "id": "form_heading_color",
      "label": "Form heading color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "form_heading_size",
      "label": "Form heading size",
      "min": 16,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "form_heading_weight",
      "label": "Form heading weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "400" },
        { "value": "500", "label": "500" },
        { "value": "600", "label": "600" },
        { "value": "700", "label": "700" },
        { "value": "800", "label": "800" },
        { "value": "900", "label": "900" }
      ]
    },
    {
      "type": "range",
      "id": "form_heading_line_height",
      "label": "Form heading line height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "form_heading_letter_spacing",
      "label": "Form heading letter spacing",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "form_heading_margin_bottom",
      "label": "Form heading bottom spacing",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "form_heading_uppercase",
      "label": "Uppercase form heading",
      "default": false
    },
    {
      "type": "color",
      "id": "form_card_bg_color",
      "label": "Form card background",
      "default": "#fafaf9"
    },
    {
      "type": "range",
      "id": "form_card_bg_opacity",
      "label": "Form card background opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "form_card_border_color",
      "label": "Form card border color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "form_card_border_opacity",
      "label": "Form card border opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 5
    },
    {
      "type": "range",
      "id": "form_card_border_width",
      "label": "Form card border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
