<section class="py-24 bg-brand-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="!grid !grid-cols-1 md:!grid-cols-2 gap-16 items-center">
      <div>
        {% if section.settings.heading != blank %}
          <h2
            class="text-3xl font-bold mb-6"
            style="
              color: {{ section.settings.heading_color }};
              font-size: {{ section.settings.heading_size }}px;
              font-weight: {{ section.settings.heading_weight }};
              letter-spacing: {{ section.settings.heading_letter_spacing }}px;
              line-height: {{ section.settings.heading_line_height }};
              text-align: {{ section.settings.heading_align }};
              margin-bottom: {{ section.settings.heading_margin_bottom }}px;
              text-transform: {% if section.settings.heading_uppercase %}uppercase{% else %}none{% endif %};
            "
          >
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <p
            class="text-white/60 mb-8 leading-relaxed"
            style="
              color: {{ section.settings.description_color }};
              font-size: {{ section.settings.description_size }}px;
              font-weight: {{ section.settings.description_weight }};
              letter-spacing: {{ section.settings.description_letter_spacing }}px;
              line-height: {{ section.settings.description_line_height }};
              text-align: {{ section.settings.description_align }};
              margin-bottom: {{ section.settings.description_margin_bottom }}px;
              max-width: {{ section.settings.description_max_width }}px;
            "
          >
            {{ section.settings.description }}
          </p>
        {% endif %}

        {% assign feature_blocks = section.blocks | where: 'type', 'feature_item' %}
        {% if feature_blocks.size > 0 %}
          <div
            class="space-y-4"
            style="              gap: {{ section.settings.feature_list_gap }}px;"
          >
            {% for block in section.blocks %}
              {% if block.type == 'feature_item' %}
                {% assign icon_color = block.settings.icon_color %}
                {% assign text_color = block.settings.text_color %}
                {% assign item_bg_alpha = block.settings.item_bg_opacity | times: 0.01 %}
                {% assign item_border_alpha = block.settings.item_border_opacity | times: 0.01 %}

                <div
                  class="flex items-center space-x-3"
                  {{ block.shopify_attributes }}
                  style="
                    justify-content:
                      {% case block.settings.item_alignment %}
                        {% when 'left' %}flex-start
                        {% when 'center' %}center
                        {% when 'right' %}flex-end
                      {% endcase %};
                    text-align: {{ block.settings.item_alignment }};
                    padding-top: {{ block.settings.item_padding_top }}px;
                    padding-right: {{ block.settings.item_padding_right }}px;
                    padding-bottom: {{ block.settings.item_padding_bottom }}px;
                    padding-left: {{ block.settings.item_padding_left }}px;
                    border-radius: {{ block.settings.item_radius }}px;
                    background: rgba({{ block.settings.item_bg_rgb.red }}, {{ block.settings.item_bg_rgb.green }}, {{ block.settings.item_bg_rgb.blue }}, {{ item_bg_alpha }});
                    border: {{ block.settings.item_border_width }}px solid rgba({{ block.settings.item_border_rgb.red }}, {{ block.settings.item_border_rgb.green }}, {{ block.settings.item_border_rgb.blue }}, {{ item_border_alpha }});
                    margin-bottom: {{ block.settings.item_margin_bottom }}px;
                    column-gap: {{ block.settings.icon_gap }}px;
                  "
                >
                  {% if block.settings.custom_icon_svg != blank %}
                    <span
                      style="
                        display: inline-flex;
                        width: {{ block.settings.icon_width }}px;
                        height: {{ block.settings.icon_height }}px;
                        color: {{ icon_color }};
                        flex-shrink: 0;
                        opacity: {{ block.settings.icon_opacity | times: 0.01 }};
                      "
                    >
                      {{ block.settings.custom_icon_svg }}
                    </span>
                  {% else %}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="{{ block.settings.icon_width }}"
                      height="{{ block.settings.icon_height }}"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="{{ block.settings.icon_stroke_width }}"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-shield text-brand-accent"
                      aria-hidden="true"
                      style="
                        color: {{ icon_color }};
                        flex-shrink: 0;
                        opacity: {{ block.settings.icon_opacity | times: 0.01 }};
                      "
                    >
                      <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                    </svg>
                  {% endif %}

                  <span
                    class="font-medium"
                    style="
                      color: {{ text_color }};
                      font-size: {{ block.settings.text_size }}px;
                      font-weight: {{ block.settings.text_weight }};
                      letter-spacing: {{ block.settings.text_letter_spacing }}px;
                      line-height: {{ block.settings.text_line_height }};
                      text-transform: {% if block.settings.text_uppercase %}uppercase{% else %}none{% endif %};
                    "
                  >
                    {{ block.settings.text }}
                  </span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% assign badge_blocks = section.blocks | where: 'type', 'badge_item' %}
      {% if badge_blocks.size > 0 %}
        <div
          class="!grid !grid-cols-2 gap-4"
          style="            gap: {{ section.settings.badge_grid_gap }}px;"
        >
          {% for block in section.blocks %}
            {% if block.type == 'badge_item' %}
              {% assign badge_bg_alpha = block.settings.badge_bg_opacity | times: 0.01 %}
              {% assign badge_border_alpha = block.settings.badge_border_opacity | times: 0.01 %}

              <div
                class="aspect-square bg-white/5 rounded-2xl flex items-center justify-center p-8 text-center"
                {{ block.shopify_attributes }}
                style="
                  aspect-ratio: {{ block.settings.badge_aspect_ratio }};
                  padding: {{ block.settings.badge_padding }}px;
                  border-radius: {{ block.settings.badge_radius }}px;
                  background: rgba({{ block.settings.badge_bg_rgb.red }}, {{ block.settings.badge_bg_rgb.green }}, {{ block.settings.badge_bg_rgb.blue }}, {{ badge_bg_alpha }});
                  border: {{ block.settings.badge_border_width }}px solid rgba({{ block.settings.badge_border_rgb.red }}, {{ block.settings.badge_border_rgb.green }}, {{ block.settings.badge_border_rgb.blue }}, {{ badge_border_alpha }});
                  opacity: {{ block.settings.badge_opacity | times: 0.01 }};
                  min-height: {{ block.settings.badge_min_height }}px;
                "
              >
                <span
                  class="text-xs font-bold uppercase tracking-widest text-brand-accent"
                  style="
                    color: {{ block.settings.text_color }};
                    font-size: {{ block.settings.text_size }}px;
                    font-weight: {{ block.settings.text_weight }};
                    letter-spacing: {{ block.settings.text_letter_spacing }}px;
                    line-height: {{ block.settings.text_line_height }};
                    text-transform: {% if block.settings.text_uppercase %}uppercase{% else %}none{% endif %};
                  "
                >
                  {{ block.settings.text }}
                </span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

